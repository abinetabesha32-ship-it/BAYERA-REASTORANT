html name=index.html <!DOCTYPE html> <html lang="en"> <head> <meta charset="UTF-8"> <meta name="viewport" content="width=device-width, initial-scale=1.0"> <title>BAYYERA RESTAURANT</title> <link rel="stylesheet" href="style.css"> <link rel="icon" href="logo.png"> <!-- Google Fonts for Modern Feel --> <link href="https://fonts.googleapis.com/css?family=Montserrat:700,400&display=swap" rel="stylesheet"> <!-- FontAwesome for Icons --> <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"> </head> <body> <!-- Header / Hero Section --> <header id="home" class="hero"> <nav class="navbar"> <div class="logo"> <img src="logo.png" alt="BAYYERA RESTAURANT logo"> <span>BAYYERA RESTAURANT</span> </div> <ul class="nav-links"> <li><a href="#home">Home</a></li> <li><a href="#categories">Menu</a></li> <li><a href="#order">Order</a></li> <li><a href="#reviews">Reviews</a></li> <li><a href="#about">About</a></li> <li><a href="#contact">Contact</a></li> </ul> <div class="mobile-menu"><i class="fas fa-bars"></i></div> </nav> <div class="hero-content"> <h1 class="hero-title">Welcome to <span>BAYYERA RESTAURANT</span></h1> <p class="hero-slogan">Classic Flavors, Modern Taste & Experience!</p> <a href="#order" class="order-btn">Order Now</a> </div> <div class="hero-3d-bg"></div> </header> <!-- Categories Section --> <section id="categories" class="categories"> <h2 class="section-title">Menu Categories</h2> <div class="category-tabs"> <button class="tab active" data-category="foods">Foods</button> <button class="tab" data-category="drinks">Drinks</button> <button class="tab" data-category="desserts">Desserts</button> <button class="tab" data-category="breakfast">Breakfast</button> <button class="tab" data-category="lunch">Lunch</button> <button class="tab" data-category="dinner">Dinner</button> <button class="tab" data-category="special">Special Menu</button> <button class="tab" data-category="coffee">Coffee</button> <button class="tab" data-category="fastfood">Fast Food</button> </div> <div class="food-cards" id="food-cards"> <!-- Food cards generated by script.js --> </div> </section> <!-- Order Section --> <section id="order" class="order-section"> <h2 class="section-title">Your Order</h2> <div class="order-cart"> <ul class="cart-items" id="cart-items"></ul> <div class="cart-summary"> <span>Total: $<span id="cart-total">0.00</span></span> <button class="place-order-btn" id="place-order-btn">Place Order</button> </div> </div> </section> <!-- Rating & Reviews Section --> <section id="reviews" class="reviews-section"> <h2 class="section-title">Customer Reviews</h2> <form class="review-form" id="review-form"> <label> Your rating: <span class="review-stars" id="review-stars"> <!-- Star rating logic in script.js --> </span> </label> <input type="text" id="reviewer-name" placeholder="Your Name" required> <textarea id="review-text" placeholder="Leave a review..." required></textarea> <button type="submit">Submit Review</button> </form> <div class="reviews-list" id="reviews-list"> <!-- Reviews rendered in script.js --> </div> </section> <!-- About Section --> <section id="about" class="about-section"> <h2 class="section-title">About BAYYERA RESTAURANT</h2> <div class="about-content"> <img src="about-bg.jpg" alt="Restaurant interior" class="about-image"> <div class="about-text glass-card"> <p> Established in 2021, BAYYERA RESTAURANT blends tradition and innovation, offering a curated menu inspired by timeless recipes and contemporary tastes. Our chefs use the freshest ingredients to deliver excellence in every bite. Whether it's a family dinner, a celebration, or a quick coffee, enjoy our classic flavors served in a modern ambiance. We invite you to experience warmth, quality, and hospitality that makes you feel at home! </p> </div> </div> </section> <!-- Contact Section --> <section id="contact" class="contact-section"> <h2 class="section-title">Contact Us</h2> <div class="contact-content"> <div class="contact-info"> <div><i class="fas fa-phone"></i> <span>+1 234 567 8901</span></div> <div><i class="fas fa-envelope"></i> <span>info@bayyerarestaurant.com</span></div> <div><i class="fas fa-map-marker-alt"></i> <span>123 Culinary Ave, Food City</span></div> <!-- Simple embed map (Google Maps Static API or similar) --> <iframe src="https://maps.google.com/maps?q=food%20city&t=&z=13&ie=UTF8&iwloc=&output=embed" width="100%" height="180" style="border-radius: 14px; border: 1px solid rgba(255,255,255,0.3);" allowfullscreen="" loading="lazy"></iframe> <div class="social-icons"> <a href="#"><i class="fab fa-facebook-f"></i></a> <a href="#"><i class="fab fa-instagram"></i></a> <a href="#"><i class="fab fa-twitter"></i></a> </div> </div> <form class="contact-form" id="contact-form"> <input type="text" placeholder="Your Name" required> <input type="email" placeholder="Email" required> <textarea placeholder="Your Message" required></textarea> <button type="submit">Send</button> </form> </div> </section> <!-- Footer --> <footer class="footer"> <div class="footer-logo"> <img src="logo.png" alt="BAYYERA logo"> <span>BAYYERA RESTAURANT</span> </div> <div class="footer-links"> <a href="#home">Home</a> <a href="#categories">Menu</a> <a href="#about">About</a> <a href="#contact">Contact</a> </div> <div class="footer-hours"> <b>Opening Hours:</b><br> Mon-Sun: 07:00 AM - 11:00 PM </div> <div class="footer-copy"> &copy; 2026 BAYYERA RESTAURANT. All rights reserved. </div> </footer> <script src="script.js"></script> </body> </html>
